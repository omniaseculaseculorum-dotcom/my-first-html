<script>
const textElement = document.getElementById("christText");

function loopText(){
    textElement.textContent = "Jesus";

    setTimeout(() => {
        textElement.textContent = "Jesus is the Christ";

        setTimeout(() => {
            loopText();
        }, 3000);   // 3 second pause after full phrase

    }, 2000);       // 2 second pause after "Jesus"
}

loopText();
</script>

